{
  "name": "reverse-archive",
  "version": "0.1.0-rc.1",
  "description": "《逆序档案》因果时间轴卡牌肉鸽",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --mode pages",
    "build:offline": "tsc -b && vite build --mode offline",
    "package:offline": "pnpm build:offline && tsx scripts/package-release.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false",
    "simulate": "tsx scripts/simulate.ts"
  },
  "keywords": [
    "card-game",
    "roguelike",
    "causality"
  ],
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fflate": "0.8.2",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-singlefile": "2.3.3",
    "vitest": "^4.1.10"
  }
}
